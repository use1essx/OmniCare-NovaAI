# =============================================================================
# OmniCare Healthcare AI Platform - Environment Configuration Template
# =============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Replace ALL placeholder values with your real credentials
# 3. NEVER commit .env to version control
# 4. Keep your credentials secure and private
#
# SECURITY WARNING:
# - This file contains PLACEHOLDER values only
# - The .env file contains your REAL credentials
# - NEVER share your .env file with anyone
# - NEVER commit .env to git (it's in .gitignore)
#
# =============================================================================

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

APP_NAME="Healthcare AI V2"
APP_VERSION="2.0.0"
ENVIRONMENT=development
DEBUG=False

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=False

# API Configuration
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# SECURITY (MUST CHANGE IN PRODUCTION)
# =============================================================================
# ⚠️  CHANGE_IN_PRODUCTION - Generate a secure random key (min 32 characters)
# Example: openssl rand -hex 32
SECRET_KEY=CHANGE_IN_PRODUCTION_generate_secure_random_key_min_32_chars

# =============================================================================
# SUPER ADMIN CONFIGURATION
# =============================================================================
# Super admin user is created automatically on application startup
# ⚠️  CHANGE_IN_PRODUCTION - Use strong credentials
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=CHANGE_IN_PRODUCTION_use_strong_password
SUPER_ADMIN_EMAIL=admin@healthcare.ai

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# DATABASE CONFIGURATION (CRITICAL - CHANGE THESE!)
# =============================================================================

DATABASE_NAME=healthcare_ai_v2
DATABASE_USER=admin
# ⚠️  CHANGE_IN_PRODUCTION - Use a strong, unique password
DATABASE_PASSWORD=CHANGE_IN_PRODUCTION_use_strong_password_here
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Demo Data Seeding (Set to False in production!)
SEED_DEMO_DATA=True

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# AWS BEDROCK CONFIGURATION - Amazon Nova (Primary AI Provider)
# =============================================================================
# AWS Bedrock is the primary and only AI provider for this application
# All AI features use AWS Nova models (Lite and Pro) and Titan Embeddings

# AWS Credentials (REQUIRED)
# Get from: IAM Console > Users > bedrock-healthcare-ai > Security credentials
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=us-east-1

# Nova Model Configuration
# Nova Lite: Fast, cost-effective for simple tasks ($0.00006/1K input, $0.00024/1K output)
# Nova Pro: Advanced reasoning for complex tasks ($0.0008/1K input, $0.0032/1K output)
NOVA_LITE_MODEL_ID=amazon.nova-2-lite-v1:0
NOVA_PRO_MODEL_ID=amazon.nova-pro-v1:0

# Titan Embeddings Configuration
# Titan Embeddings: For knowledge base search and document embeddings
TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v1

# Budget Protection ($50 hard limit)
# CRITICAL: Hard-coded $50 limit enforced in application code
# This prevents runaway costs and ensures hackathon compliance
BUDGET_LIMIT_USD=50.00
BUDGET_WARNING_THRESHOLD=0.80
ENABLE_COST_TRACKING=true

# =============================================================================
# KNOWLEDGE BASE / RAG CONFIGURATION
# =============================================================================
# Enable RAG (Retrieval-Augmented Generation) for knowledge base
RAG_ENABLED=true

# =============================================================================
# AI SEMANTIC CHUNKING CONFIGURATION
# =============================================================================
# Feature flag to enable AI-enhanced semantic chunking for knowledge base documents
# When enabled, documents are chunked at natural semantic boundaries with AI-generated metadata
# When disabled, uses simple paragraph-based chunking (backward compatible)
AI_SEMANTIC_CHUNKING_ENABLED=false

# AI Service Configuration for Semantic Chunking
# Timeout for AI service calls during chunking (in seconds)
SEMANTIC_CHUNK_TIMEOUT=30

# Maximum number of concurrent AI requests for metadata generation
SEMANTIC_CHUNK_MAX_CONCURRENT=5

# Chunk Size Configuration
# Minimum chunk size in characters (prevents chunks that are too small)
SEMANTIC_CHUNK_MIN_SIZE=200

# Maximum chunk size in characters (prevents chunks that are too large)
SEMANTIC_CHUNK_MAX_SIZE=1200

# Target chunk size for low complexity content (simple explanatory text)
SEMANTIC_CHUNK_TARGET_LOW=1000

# Target chunk size for medium complexity content (standard informational content)
SEMANTIC_CHUNK_TARGET_MEDIUM=650

# Target chunk size for high complexity content (dense technical content)
SEMANTIC_CHUNK_TARGET_HIGH=450

# Maximum overlap between consecutive chunks in characters (preserves context)
SEMANTIC_CHUNK_MAX_OVERLAP=150

# =============================================================================
# AGENT SYSTEM CONFIGURATION
# =============================================================================

# Agent Configuration
DEFAULT_AGENT_TIMEOUT=30
MAX_CONVERSATION_HISTORY=50
AGENT_CONFIDENCE_THRESHOLD=0.6

# Agent Routing
ENABLE_INTELLIGENT_ROUTING=True
ROUTING_MODEL=gpt-4-turbo-preview
URGENCY_DETECTION_THRESHOLD=0.8

# Cultural Settings
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,zh-HK
CULTURAL_CONTEXT=hong_kong

# =============================================================================
# LOGGING AND MONITORING CONFIGURATION
# =============================================================================

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/healthcare_ai.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# Logging Categories
LOG_DATABASE_QUERIES=False
LOG_API_REQUESTS=True
LOG_AGENT_INTERACTIONS=True
LOG_SECURITY_EVENTS=True

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=9090
ENABLE_HEALTH_CHECKS=True
HEALTH_CHECK_INTERVAL=30

# Error Tracking (Optional - Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# BACKGROUND TASKS CONFIGURATION
# =============================================================================

# Worker Configuration
WORKER_CONCURRENCY=4
WORKER_MAX_TASKS_PER_CHILD=1000

# Task Queues
ENABLE_BACKGROUND_TASKS=True

# Scheduled Tasks
ENABLE_DATA_SYNC=True
DATA_SYNC_INTERVAL=3600

ENABLE_LEARNING_UPDATES=True
LEARNING_UPDATE_INTERVAL=86400

ENABLE_CLEANUP_TASKS=True
CLEANUP_INTERVAL=604800

# =============================================================================
# SECURITY MONITORING CONFIGURATION
# =============================================================================

# Security Event Tracking
ENABLE_SECURITY_MONITORING=True
SECURITY_ALERT_EMAIL=security@healthcare-ai.com
ADMIN_EMAILS=admin@healthcare-ai.com

# SMTP Configuration for Security Alerts
SMTP_SERVER=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=security@healthcare-ai.com

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#security-alerts

# Security Thresholds
FAILED_LOGIN_THRESHOLD=5
BRUTE_FORCE_THRESHOLD=10
RATE_LIMIT_VIOLATION_THRESHOLD=10

# IP Blocking
AUTO_BLOCK_SUSPICIOUS_IPS=True
DEFAULT_IP_BLOCK_DURATION_MINUTES=60

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# ⚠️  For production, set ENVIRONMENT=production and DEBUG=false
ENVIRONMENT=development
DEBUG=true
KB_SANDBOX_DEV_MODE=true
KB_SANDBOX_DEV_ORG_ID=1
LOG_LEVEL=INFO

# Service Ports
HEALTHCARE_AI_PORT=8000
LIVE2D_PORT=8080
PGADMIN_PORT=5050
STT_PORT=8790
TTS_PORT=8791
MOTION_PORT=8001
ASSESSMENT_PORT=8002

# =============================================================================
# PGADMIN CONFIGURATION
# =============================================================================
PGADMIN_EMAIL=admin@healthcare-ai.com
# ⚠️  CHANGE_IN_PRODUCTION - Use a strong password
PGADMIN_PASSWORD=CHANGE_IN_PRODUCTION_use_strong_password

# =============================================================================
# LIVE2D CONFIGURATION
# =============================================================================
ENABLE_LIVE2D=true
DEFAULT_LIVE2D_MODEL=Hiyori
LIVE2D_MODELS_PATH=/app/src/web/live2d/Samples/TypeScript/Demo/dist/Resources

# =============================================================================
# SPEECH SERVICES CONFIGURATION
# =============================================================================
ENABLE_STT=false
STT_MODEL=tiny
STT_LANGUAGE=en
TTS_DEFAULT_VOICE=zh-HK-HiuGaaiNeural

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_ADMIN_INTERFACE=true
ENABLE_API_DOCS=true
ENABLE_HEALTH_CHECKS=true
ENABLE_SECURITY_MONITORING=true
ENABLE_BACKGROUND_TASKS=true

# =============================================================================
# HONG KONG DATA PIPELINE
# =============================================================================
HK_DATA_UPDATE_INTERVAL=3600
HK_DATA_CACHE_TTL=1800
HK_DATA_RETRY_ATTEMPTS=3

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# ⚠️  Update for your production domain
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:8000"]

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# Before deploying to production, ensure you have:
# [ ] Changed DATABASE_PASSWORD to a strong password
# [ ] Changed SECRET_KEY to a secure random string (min 32 chars)
# [ ] Changed PGADMIN_PASSWORD to a strong password
# [ ] Changed SUPER_ADMIN_PASSWORD to a strong password
# [ ] Changed SUPER_ADMIN_EMAIL to your organization email
# [ ] Set ENVIRONMENT=production
# [ ] Set DEBUG=false
# [ ] Updated CORS_ORIGINS for your domain
# [ ] Set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY for Bedrock
# [ ] Configured HTTPS/SSL
# [ ] Set up database backups
# =============================================================================
